# Example Nginx reverse proxy for agentweekly.in (Next.js + FastAPI in Docker).
# Install: copy to /etc/nginx/conf.d/agentweekly.conf and adjust ssl_certificate paths after Certbot.
#
# Prerequisites on VPS:
#   - Docker exposes 127.0.0.1:3000 (web) and 127.0.0.1:8000 (api) OR bind Compose to host loopback only.
#   - DNS A records: agentweekly.in, www.agentweekly.in, api.agentweekly.in → 45.195.159.159
#
# First-time HTTPS (Certbot nginx plugin):
#   dnf install -y certbot python3-certbot-nginx   # or apt install certbot python3-certbot-nginx
#   nginx -t && systemctl reload nginx
#   certbot --nginx -d agentweekly.in -d www.agentweekly.in -d api.agentweekly.in
#
# After certificates exist, uncomment the server { listen 443 ssl; ... } blocks below or merge
# Certbot-managed snippets. Below shows a typical post-cert layout.

upstream next_app {
    server 127.0.0.1:3000;
    keepalive 32;
}

upstream fastapi_app {
    server 127.0.0.1:8000;
    keepalive 32;
}

# HTTP: ACME challenge + redirect to HTTPS
server {
    listen 80;
    listen [::]:80;
    server_name agentweekly.in www.agentweekly.in;

    location /.well-known/acme-challenge/ {
        root /var/www/certbot;
    }

    location / {
        return 301 https://agentweekly.in$request_uri;
    }
}

server {
    listen 80;
    listen [::]:80;
    server_name api.agentweekly.in;

    location /.well-known/acme-challenge/ {
        root /var/www/certbot;
    }

    location / {
        return 301 https://api.agentweekly.in$request_uri;
    }
}

server {
    listen 443 ssl http2;
    listen [::]:443 ssl http2;
    server_name agentweekly.in www.agentweekly.in;

    ssl_certificate     /etc/letsencrypt/live/agentweekly.in/fullchain.pem;
    ssl_certificate_key /etc/letsencrypt/live/agentweekly.in/privkey.pem;
    include /etc/letsencrypt/options-ssl-nginx.conf;
    ssl_dhparam /etc/letsencrypt/ssl-dhparams.pem;

    location / {
        proxy_pass http://next_app;
        proxy_http_version 1.1;
        proxy_set_header Host $host;
        proxy_set_header X-Real-IP $remote_addr;
        proxy_set_header X-Forwarded-For $proxy_add_x_forwarded_for;
        proxy_set_header X-Forwarded-Proto $scheme;
        proxy_set_header Upgrade $http_upgrade;
        proxy_set_header Connection "upgrade";
    }
}

server {
    listen 443 ssl http2;
    listen [::]:443 ssl http2;
    server_name api.agentweekly.in;

    ssl_certificate     /etc/letsencrypt/live/agentweekly.in/fullchain.pem;
    ssl_certificate_key /etc/letsencrypt/live/agentweekly.in/privkey.pem;
    include /etc/letsencrypt/options-ssl-nginx.conf;
    ssl_dhparam /etc/letsencrypt/ssl-dhparams.pem;

    location / {
        proxy_pass http://fastapi_app;
        proxy_http_version 1.1;
        proxy_set_header Host $host;
        proxy_set_header X-Real-IP $remote_addr;
        proxy_set_header X-Forwarded-For $proxy_add_x_forwarded_for;
        proxy_set_header X-Forwarded-Proto $scheme;
    }
}
