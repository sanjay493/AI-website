# Use this BEFORE Certbot if you need plain HTTP only on port 80 (no TLS yet).
# Copy to /etc/nginx/conf.d/agentweekly.conf → nginx -t && systemctl reload nginx
# Then run: certbot --nginx -d agentweekly.in -d www.agentweekly.in -d api.agentweekly.in

server {
    listen 80;
    listen [::]:80;
    server_name agentweekly.in www.agentweekly.in;

    location / {
        proxy_pass http://127.0.0.1:3000;
        proxy_http_version 1.1;
        proxy_set_header Host $host;
        proxy_set_header X-Real-IP $remote_addr;
        proxy_set_header X-Forwarded-For $proxy_add_x_forwarded_for;
        proxy_set_header X-Forwarded-Proto $scheme;
    }
}

server {
    listen 80;
    listen [::]:80;
    server_name api.agentweekly.in;

    location / {
        proxy_pass http://127.0.0.1:8000;
        proxy_http_version 1.1;
        proxy_set_header Host $host;
        proxy_set_header X-Real-IP $remote_addr;
        proxy_set_header X-Forwarded-For $proxy_add_x_forwarded_for;
        proxy_set_header X-Forwarded-Proto $scheme;
    }
}
