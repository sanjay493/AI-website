# Copy to .env and adjust for local development
APP_NAME=AI Signal API
ENVIRONMENT=development
DEBUG=true
HOST=0.0.0.0
PORT=8000

# Optional: comma-separated hostnames for TrustedHostMiddleware (e.g. api.localhost,localhost).
# Leave empty locally; set in production behind a reverse proxy.
# ALLOWED_HOSTS=api.example.com,localhost

# Comma-separated origins (no spaces) for browser clients
CORS_ORIGINS=http://localhost:3000,http://127.0.0.1:3000

# Frontend base URL for password reset links (Docker: http://localhost:3000)
FRONTEND_BASE_URL=http://localhost:3000

# When this email registers, grant admin automatically (omit to disable bootstrap)
FIRST_ADMIN_EMAIL=you@yourdomain.com

# Postgres
DATABASE_URL=postgresql+asyncpg://user:password@localhost:5432/ai_signal

# Redis — queues / Celery / caching later
REDIS_URL=redis://localhost:6379/0

# JWT signing (use a strong random string in shared environments)
SECRET_KEY=change-me-in-production

# Tokens
ACCESS_TOKEN_EXPIRE_MINUTES=30
REFRESH_TOKEN_EXPIRE_DAYS=7
PASSWORD_RESET_EXPIRE_MINUTES=60
