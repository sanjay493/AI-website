# Copy to `.env.production` on your Hostinger VPS (never commit secrets).
POSTGRES_USER=postgres
POSTGRES_PASSWORD=changeme-strong
POSTGRES_DB=ai_signal

SECRET_KEY=use-openssl-rand-hex-32-or-similar
FIRST_ADMIN_EMAIL=you@yourdomain.com

# Canonical site URL (HTTPS behind proxy).
NEXT_PUBLIC_SITE_URL=https://yourdomain.com

# Browser calls same-origin `/api/v1`; Next proxies to FastAPI inside Docker (simplest HTTPS setup).
NEXT_PUBLIC_API_URL=/api/v1

FRONTEND_BASE_URL=https://yourdomain.com
CORS_ORIGINS=https://yourdomain.com

# With same-origin `/api/v1`, leave empty unless you expose the API on its own hostname.
ALLOWED_HOSTS=

# Optional: override RSS/Atom list (comma or newline). Defaults include arXiv, Google AI blog, Google News AI, + one YT channel RSS.
# NEWS_INGEST_FEED_URLS=https://arxiv.org/rss/cs.AI

# Optional: YouTube Data API key for regional *trending* videos (chart=mostPopular, see docs).
# YOUTUBE_API_KEY=
# YOUTUBE_TRENDING_REGION=US
# YOUTUBE_TRENDING_MAX_RESULTS=40
# YOUTUBE_TRENDING_VIDEO_CATEGORY_ID=28
# Default: AI-only trending filter inspects title, short description, and snippet tags.
# YOUTUBE_TRENDING_AI_ONLY=true
# Comma-separated extra substrings beyond built-in list (optional).
# YOUTUBE_TRENDING_AI_KEYWORDS=agentic ai,graph neural

# Optional: secret for weekly server cron — POST /api/v1/admin/news-agent/ingest/scheduled
# with header X-News-Ingest-Secret: <same value>
# NEWS_INGEST_CRON_SECRET=

