# Copy to `.env.production` on your Hostinger VPS (never commit secrets).
POSTGRES_USER=postgres
POSTGRES_PASSWORD=changeme-strong
POSTGRES_DB=ai_signal

SECRET_KEY=use-openssl-rand-hex-32-or-similar
FIRST_ADMIN_EMAIL=you@yourdomain.com

# Public URLs (HTTPS once TLS is terminated at Nginx/Caddy/Cloudflare)
NEXT_PUBLIC_SITE_URL=https://yourdomain.com
NEXT_PUBLIC_API_URL=https://api.yourdomain.com/api/v1
FRONTEND_BASE_URL=https://yourdomain.com
CORS_ORIGINS=https://yourdomain.com

# If API is subdomain, set TrustedHost-style list (comma-separated, no schemes)
ALLOWED_HOSTS=api.yourdomain.com
